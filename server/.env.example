# Broderick Terminal Server — Environment Variables
# Copy this file to .env for local development
# In production (Render), set these as environment variables in the dashboard

# JWT signing secret — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
BRODERICK_SECRET=change-me-before-deploying

# PostgreSQL connection string
# Set automatically by Render when you attach a managed database
# For local dev,  leave blank and SQLite will be used instead
DATABASE_URL=

# Finnhub API key — free tier available at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# AISStream API key — free tier available at https://aisstream.io
AISSTREAM_API_KEY=your_aisstream_api_key_here

# SQLite path for local development (ignored if DATABASE_URL is set)
# BRODERICK_DB=./broderick.db
